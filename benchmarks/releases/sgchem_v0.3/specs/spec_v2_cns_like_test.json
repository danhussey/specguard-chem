{
  "behaviour": {
    "abstain_policy": {
      "margin_lt": {
        "TPSA": 5.0,
        "logP": 0.2
      }
    },
    "interrupt_policy": "confirm_then_continue"
  },
  "constraints": [
    {
      "check": "property_bounds",
      "id": "cns_bounds",
      "params": {
        "bounds": {
          "HBA": {
            "max": 8.0,
            "min": 0.0
          },
          "HBD": {
            "max": 2.0,
            "min": 0.0
          },
          "MW": {
            "max": 420.0,
            "min": 150.0
          },
          "ROTB": {
            "max": 8.0,
            "min": 0.0
          },
          "TPSA": {
            "max": 90.0,
            "min": 20.0
          },
          "logP": {
            "max": 4.0,
            "min": 1.0
          }
        },
        "mode": "all"
      },
      "severity": null,
      "type": "hard",
      "weight": 1.0
    },
    {
      "check": "sa_proxy_max",
      "id": "sa_limit",
      "params": {
        "max": 5.5
      },
      "severity": null,
      "type": "hard",
      "weight": 1.0
    },
    {
      "check": "alert_set_absent",
      "id": "pains_a_soft",
      "params": {
        "alert_set": "PAINS_A"
      },
      "severity": null,
      "type": "soft",
      "weight": 0.5
    }
  ],
  "family": "cns_like",
  "id": "spec_v2_cns_like_test",
  "spec_split": "test",
  "version": 2
}
