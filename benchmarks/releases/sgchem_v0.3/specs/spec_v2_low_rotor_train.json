      "id": "low_rotor_bounds",
      "params": {
        "bounds": {
          "HBA": {
            "max": 10.0,
            "min": 0.0
          },
          "HBD": {
            "max": 5.0,
            "min": 0.0
          },
          "MW": {
            "max": 480.0,
            "min": 120.0
          },
          "ROTB": {
            "max": 4.0,
            "min": 0.0
          },
          "logP": {
            "max": 4.5,
            "min": -1.0
          }
        },
        "mode": "all"
      },
      "severity": null,
      "type": "hard",
      "weight": 1.0
    },
    {
      "check": "property_bounds",
      "id": "tpsa_soft_window",
      "params": {
        "bounds": {
          "TPSA": {
            "max": 120.0,
            "min": 20.0
          }
        },
        "mode": "any"
      },
      "severity": null,
      "type": "soft",
      "weight": 0.5
    }
  ],
  "family": "flexibility",
  "id": "spec_v2_low_rotor_train",
  "spec_split": "train",
  "version": 2
