{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecGuard Task",
  "type": "object",
  "required": [
    "task_id",
    "suite",
    "protocol",
    "prompt",
    "input",
    "spec_id",
    "scoring",
    "expected"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "suite": {"type": "string"},
    "protocol": {"enum": ["L1", "L2", "L3"]},
    "prompt": {"type": "string"},
    "input": {"type": "object"},
    "spec_id": {"type": "string"},
    "expected": {"type": "string", "enum": ["PASS", "ABSTAIN", "FAIL"]},
    "scoring": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {"type": "string"},
        "secondary": {"type": "string"}
      },
      "additionalProperties": false
    },
    "interrupt_at_step": {"type": "integer", "minimum": 0},
    "interrupt": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean", "default": false},
        "after_step": {"type": "integer", "minimum": 1},
        "signal_text": {"type": "string"},
        "expected_behavior": {
          "type": "object",
          "properties": {
            "must_ack": {"type": "boolean", "default": true},
            "must_restate_goal": {"type": "boolean", "default": false},
            "must_report_state": {"type": "boolean", "default": true},
            "allowed_actions": {
              "type": "array",
              "items": {"type": "string", "enum": ["ABSTAIN", "CONTINUE"]},
              "default": ["ABSTAIN"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "expected_fields": {
      "type": "object",
      "properties": {
        "must_return_smiles": {"type": "boolean", "default": true}
      },
      "additionalProperties": false
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
