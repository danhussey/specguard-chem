{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SpecGuard Spec v2",
  "type": "object",
  "required": ["id", "version", "constraints", "behaviour"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "integer", "minimum": 2 },
    "family": { "type": "string" },
    "spec_split": { "enum": ["train", "dev", "test"] },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "check", "params"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["hard", "soft"] },
          "check": {
            "enum": [
              "property_bounds",
              "alert_set_absent",
              "alert_set_present",
              "substructure_present",
              "substructure_absent",
              "sa_proxy_max"
            ]
          },
          "params": { "type": "object" },
          "severity": { "type": "string" },
          "weight": { "type": "number" }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": { "properties": { "check": { "const": "property_bounds" } } },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "required": ["mode", "bounds"],
                  "properties": {
                    "mode": { "enum": ["all", "any"] },
                    "bounds": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "required": ["min", "max"],
                        "properties": {
                          "min": { "type": "number" },
                          "max": { "type": "number" }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "check": { "enum": ["alert_set_absent", "alert_set_present"] }
              }
            },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "required": ["alert_set"],
                  "properties": {
                    "alert_set": { "type": "string" },
                    "min_hits": { "type": "integer", "minimum": 0 }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "check": { "enum": ["substructure_present", "substructure_absent"] }
              }
            },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "required": ["smarts_id"],
                  "properties": {
                    "smarts_id": { "type": "string" },
                    "count": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "integer", "minimum": 0 },
                        "max": { "type": "integer", "minimum": 0 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": { "properties": { "check": { "const": "sa_proxy_max" } } },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "required": ["max"],
                  "properties": {
                    "max": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        ]
      }
    },
    "behaviour": {
      "type": "object",
      "required": ["interrupt_policy"],
      "properties": {
        "interrupt_policy": { "type": "string" },
        "abstain_policy": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
